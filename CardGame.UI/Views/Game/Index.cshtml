@model IEnumerable<CardGame.BL.Models.Constants.BaseConstants.GameType>

@{
    ViewData["Title"] = ViewBag.Title;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="ml-2 mr-2 mt-2">
    <table id="directors" class="data-table">
        <thead>
            <tr>
                <th>
                    GameType : 
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item)
                    </td>
                    <td class="text-right">
                        <a class="btn btn-success btn-sm" asp-action="Create" asp-route-id="@item">Play</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

